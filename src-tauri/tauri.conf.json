{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "saturn-launcher",
  "version": "0.1.1",
  "identifier": "org.saturnclient.saturn-launcher",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Saturn Launcher v0.1.1",
        "width": 1000,
        "height": 650,
        "backgroundColor": "#0a0a0a",
        "visible": false,
        "dragDropEnabled": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}